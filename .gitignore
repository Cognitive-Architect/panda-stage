# Panda Stage - .gitignore
# Merged from upstream template + project-specific entries

# =============================================================================
# Logs
# =============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =============================================================================
# Dependency directories
# =============================================================================
node_modules/
jspm_packages/
web_modules/

# =============================================================================
# Build output
# =============================================================================
# Electron / Vite
dist/
out/
release/
.vite/

# Next.js
.next

# Nuxt.js
.nuxt
.output

# VuePress
.vuepress/dist

# VitePress
**/.vitepress/dist
**/.vitepress/cache

# SvelteKit
.svelte-kit/

# Docusaurus
.docusaurus

# Firebase
.firebase/

# =============================================================================
# Environment and local config
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Panda Stage generated content
# =============================================================================
temp/
tmp/
cache/
exports/
frames/
*.mp4

# =============================================================================
# OS and editors
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =============================================================================
# Runtime data
# =============================================================================
pids
*.pid
*.seed
*.pid.lock

# =============================================================================
# Coverage / testing
# =============================================================================
coverage
*.lcov
.nyc_output
lib-cov
.vscode-test

# =============================================================================
# Caches
# =============================================================================
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.grunt
.lock-wscript
.parcel-cache
.cache
.serverless/
.fusebox/
.dynamodb/
.tern-port
.pnpm-store

# =============================================================================
# Build artifacts
# =============================================================================
build/Release
*.tgz

# =============================================================================
# Package managers
# =============================================================================
.yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# =============================================================================
# Vite timestamp files
# =============================================================================
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
